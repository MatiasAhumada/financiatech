DATABASE_URL="postgresql://user:password@localhost:5432/deviceguard?connection_limit=10&pool_timeout=20"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
NODE_ENV="development"
NEXT_PUBLIC_API_URL=""

# Firebase Admin SDK
# Opción 1: Usando GOOGLE_APPLICATION_CREDENTIALS (recomendado en producción)
# GOOGLE_APPLICATION_CREDENTIALS="./path/to/serviceAccountKey.json"

# Opción 2: Usando variables de entorno (desarrollo)
FIREBASE_PROJECT_ID="tu-project-id"
FIREBASE_CLIENT_EMAIL="tu-service-account@tu-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU-PRIVATE-KEY\n-----END PRIVATE KEY-----\n"
