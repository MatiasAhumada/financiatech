generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

enum DeviceStatus {
  ACTIVE
  SOLD_PENDING
  SOLD_SYNCED
  BLOCKED
  MAINTENANCE
  INACTIVE
}

enum DeviceType {
  SMARTPHONE
  TABLET
  LAPTOP
  DESKTOP
  SMARTWATCH
  OTHER
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHECK
}

enum NotificationType {
  WARNING_1
  WARNING_2
  BLOCKED
}

enum NotificationTrigger {
  SCHEDULED
  MANUAL
}

enum PhoneType {
  MOBILE
  HOME
  WORK
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     UserRole

  superAdmin SuperAdmin?
  admin      Admin?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model SuperAdmin {
  id     String @id @default(cuid())
  userId String @unique

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  admins Admin[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("super_admins")
}

model Admin {
  id           String @id @default(cuid())
  userId       String @unique
  superAdminId String

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  superAdmin     SuperAdmin      @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  devices        Device[]
  clients        Client[]
  financingPlans FinancingPlan[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("admins")
}

model Client {
  id      String  @id @default(cuid())
  name    String
  email   String?
  adminId String

  admin     Admin       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  devices   Device[]
  payments  Payment[]
  addresses Address[]
  phones    Phone[]
  sales     Sale[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("clients")
}

model Address {
  id       String  @id @default(cuid())
  street   String
  city     String
  state    String?
  zipCode  String?
  country  String?
  nota     String?
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("addresses")
}

model Phone {
  id          String    @id @default(cuid())
  number      String
  type        PhoneType
  referencia  String?
  clientId    String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("phones")
}

model Device {
  id           String       @id @default(cuid())
  name         String
  type         DeviceType
  model        String?
  serialNumber String?      @unique
  status       DeviceStatus @default(ACTIVE)
  adminId      String
  clientId     String?

  admin         Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentPlan   PaymentPlan?
  blockRule     BlockRule?
  installments  Installment[]
  sale          Sale?
  sync          DeviceSync?
  notifications Notification[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status], name: "idx_devices_status")
  @@index([adminId, status], name: "idx_devices_admin_status")
  @@map("devices")
}

model PaymentPlan {
  id            String   @id @default(cuid())
  totalAmount   Decimal  @db.Decimal(10, 2)
  installments  Int
  monthlyAmount Decimal  @db.Decimal(10, 2)
  startDate     DateTime
  endDate       DateTime
  deviceId      String   @unique

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("payment_plans")
}

model Installment {
  id         String            @id @default(cuid())
  number     Int
  amount     Decimal           @db.Decimal(10, 2)
  dueDate    DateTime
  paidAmount Decimal           @default(0) @db.Decimal(10, 2)
  status     InstallmentStatus @default(PENDING)
  deviceId   String

  device        Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  payments      Payment[]
  notifications Notification[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deviceId, status, dueDate], name: "idx_installments_device_status_due")
  @@map("installments")
}

model BlockRule {
  id               String  @id @default(cuid())
  firstWarningDay  Int
  secondWarningDay Int
  blockDay         Int
  isActive         Boolean @default(true)
  deviceId         String  @unique

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("block_rules")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  reference     String?
  clientId      String
  installmentId String

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  installment Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("payments")
}

model Sale {
  id               String           @id @default(cuid())
  deviceId         String           @unique
  clientId         String
  totalAmount      Decimal          @db.Decimal(10, 2)
  initialPayment   Decimal          @default(0) @db.Decimal(10, 2)
  installments     Int
  installmentAmount Decimal         @db.Decimal(10, 2)
  paymentFrequency PaymentFrequency @default(MONTHLY)
  activationCode   String           @unique
  saleDate         DateTime         @default(now())
  financingPlanId  String?

  device        Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  financingPlan FinancingPlan? @relation(fields: [financingPlanId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([activationCode], name: "idx_sales_activation_code")
  @@map("sales")
}

model FinancingPlan {
  id               String           @id @default(cuid())
  name             String
  installments     Int
  paymentFrequency PaymentFrequency @default(MONTHLY)
  interestRate     Decimal          @db.Decimal(5, 2)
  isActive         Boolean          @default(true)
  adminId          String

  admin Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  sales Sale[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("financing_plans")
}

model DeviceSync {
  id       String   @id @default(cuid())
  deviceId String   @unique
  imei     String   @unique
  fcmToken String?
  syncedAt DateTime @default(now())
  lastPing DateTime @default(now())

  device          Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  pendingCommands PendingCommand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastPing], name: "idx_device_syncs_lastping")
  @@map("device_syncs")
}

model PendingCommand {
  id        String   @id @default(cuid())
  deviceId  String
  type      String
  status    String   @default("PENDING")
  sentAt    DateTime?
  ackedAt   DateTime?

  deviceSync DeviceSync @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pending_commands")
}

model Notification {
  id            String               @id @default(cuid())
  deviceId      String
  installmentId String?
  type          NotificationType
  trigger       NotificationTrigger  @default(SCHEDULED)
  dayOfWeek     Int?
  dayOfMonth    Int?
  message       String
  success       Boolean              @default(true)
  errorMessage  String?
  executedBy    String?
  sentAt        DateTime             @default(now())

  device      Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  installment Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@index([deviceId, sentAt], name: "idx_notifications_device_sent")
  @@index([type, trigger], name: "idx_notifications_type_trigger")
  @@map("notifications")
}